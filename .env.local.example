# Supabase project URL — found in Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Supabase anon/public key — safe for browser use, subject to RLS
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service role key — bypasses RLS, NEVER expose to browser
# Only used in server-side API routes (/api/sync)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Any long random string — protects /api/sync from unauthorized callers
# Generate with: openssl rand -hex 32
# Must match the secret configured in Vercel cron settings
CRON_SECRET=your-long-random-secret-here
